# Never commit ".env".
# Copy this file to ``.env`` in this folder (next to ``manage.py``), then fill in values.
# Tip: save ``.env`` as UTF-8 without BOM (VS Code: click encoding in the status bar).

# --- Django ---
# Required. Generate once, e.g. with venv active from the ``backend/`` folder:
#   .\.venv\Scripts\python.exe -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Paste the output below (no quotes). Do not reuse keys across environments.
DJANGO_SECRET_KEY=

# Local development: True | Production: False
DJANGO_DEBUG=True

# Comma-separated hostnames (optional in DEBUG with empty list for runserver)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins for browser + credentials (CORS).
# Leave unset to use the default dev list in settings.py.
# DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# --- Quizly / AI ---
# Whisper model name (e.g. tiny, base, small, medium, large, turbo — needs matching openai-whisper).
WHISPER_MODEL=base
# Required for POST /api/quizzes/ (quiz JSON). Never commit the real key.
GEMINI_API_KEY=
# Optional override (default in settings is gemini-2.5-flash — see Google AI model list).
# GEMINI_MODEL=gemini-2.5-flash
# Optional. HTTP timeout for Gemini in milliseconds (default 180000).
# GEMINI_HTTP_TIMEOUT_MS=180000
